---
import '../styles/tokens.css';
import Masthead from '../components/Masthead.astro';
import RiffCard from '../components/RiffCard.astro';
import { SITE_URL, SUBMIT_URL, SUBMIT_CTA } from '../lib/site';

type Riff = { code: string; stakeholder: string; prompt: string; comeback: string };

interface Props {
  initial: Riff;
  riffs: Riff[];              // all active riffs, embedded for the client island
  seoTitle?: string;
  seoDescription?: string;
  note?: string;             // optional line (used by the 404 / retired fallback)
  ogImagePath?: string;      // per-page social card; defaults to the site-wide brand card
}

const {
  initial,
  riffs,
  seoTitle = 'PM Off Mute',
  seoDescription = "The questions every PM dreads, and the comebacks you wish you'd sent.",
  note,
  ogImagePath = '/og-image.png',
} = Astro.props;

const year = new Date().getFullYear();
const ogImage = new URL(ogImagePath, SITE_URL).href;
const canonical = new URL(Astro.url.pathname, SITE_URL).href;

const clientJson = JSON.stringify(
  riffs.map((r) => ({ code: r.code, stakeholder: r.stakeholder, prompt: r.prompt, comeback: r.comeback }))
).replace(/</g, '\\u003c');

const FILTERS = [
  { value: '', label: 'All' },
  { value: 'Sales', label: 'Sales' },
  { value: 'CS', label: 'CS' },
  { value: 'Exec', label: 'Exec' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content="Off Mute" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <Masthead />

    <nav class="toolbar" aria-label="Filter riffs by stakeholder">
      {FILTERS.map((f) => (
        <button
          class:list={['chip', { 'is-active': f.value === '' }]}
          data-filter={f.value}
          aria-pressed={f.value === '' ? 'true' : 'false'}
          type="button"
        >{f.label}</button>
      ))}
    </nav>

    <main class="reader">
      {note && <p class="reader__note" role="status">{note}</p>}
      <div class="reader__stage">
        <RiffCard
          code={initial.code}
          stakeholder={initial.stakeholder}
          prompt={initial.prompt}
          comeback={initial.comeback}
        />
      </div>
      <div class="reader__footer">
        <hr class="rule-hairline" />
        <div class="footer__row">
          <button id="next-btn" class="next" type="button">Next</button>
          <div class="actions">
            <button id="about-btn" class="ghost" type="button">About</button>
            <button id="share-btn" class="ghost" type="button">Share</button>
            <button id="save-btn" class="ghost" type="button">Save</button>
          </div>
        </div>
      </div>
    </main>

    <!-- About panel -->
    <div id="about-overlay" class="overlay" hidden>
      <div class="panel about" role="dialog" aria-modal="true" aria-label="About Off Mute">
        <button id="about-close" class="panel__close" type="button" aria-label="Close">&times;</button>
        <p>Off Mute is where product people go to lose gracefully &mdash; self-deprecation, now scalable.</p>
        <p>The questions every PM dreads from Sales, CS, and Exec &mdash; paired with the answers you wish you'd sent, instead of the serious or professional ones you did. One exchange per screen, at random, or filtered to whichever stakeholder is testing your patience today.</p>
        <p>A confession booth in reverse: not your sins, but the comebacks you were too professional to deliver. Mostly laughs, but more like laugh, laugh, oof, because under the snark there's a bruise, and crying doesn't fit in a Jira ticket.</p>
        <p class="about__closer">Because if you can laugh at it, it can't hurt you.</p>
        <a class="submit-link" href={SUBMIT_URL} target="_blank" rel="noopener noreferrer">{SUBMIT_CTA}</a>
        <hr class="about__rule" />
        <p class="about__legal">
          Created and curated by Eva Gao. The questions are comedic archetypes, not real quotes.<br />
          &copy; {year} Eva Gao. All rights reserved.
        </p>
        <p class="about__footnote">No user data collected. Non-profit.</p>
      </div>
    </div>

    <!-- Share menu -->
    <div id="share-overlay" class="overlay" hidden>
      <div class="panel share" role="dialog" aria-modal="true" aria-label="Share this riff">
        <button id="share-close" class="panel__close" type="button" aria-label="Close">&times;</button>
        <p class="panel__title">Share this riff</p>
        <button id="share-copy" class="share-item" type="button">Copy link</button>
        <button id="share-native" class="share-item" type="button" hidden>Share&hellip;</button>
        <a id="share-x" class="share-item" target="_blank" rel="noopener noreferrer">X / Twitter</a>
        <a id="share-li" class="share-item" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a id="share-wa" class="share-item" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <a id="share-email" class="share-item">Email</a>
      </div>
    </div>

    <script type="application/json" id="riffs-data" set:html={clientJson}></script>
    <script>
      import '../scripts/reader.ts';
    </script>

    <style>
      .toolbar {
        max-width: var(--measure);
        margin: 0 auto;
        padding: var(--sp-4) var(--margin-mobile) 0;
        display: flex;
        gap: var(--sp-2);
        flex-wrap: wrap;
      }
      .chip {
        font-family: var(--sans);
        font-size: var(--fs-label);
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 7px 12px;
        border: 1px solid var(--ink);
        border-radius: var(--radius);
        background: transparent;
        color: var(--ink);
        cursor: pointer;
      }
      .chip.is-active { background: var(--structure); color: var(--on-structure); border-color: var(--structure); }

      .reader {
        flex: 1;
        width: 100%;
        max-width: var(--measure);
        margin: 0 auto;
        padding: var(--sp-5) var(--margin-mobile) var(--sp-5);
        display: flex;
        flex-direction: column;
      }
      .reader__note {
        font-family: var(--sans);
        font-size: 13px;
        color: var(--muted);
        margin: 0 0 var(--sp-4);
      }
      .reader__stage { flex: 1; display: flex; flex-direction: column; justify-content: center; }
      #riff-card { width: 100%; cursor: pointer; }

      .reader__footer { padding-top: var(--sp-5); }
      .rule-hairline { height: var(--rule-hairline); background: var(--hairline); border: 0; margin: 0 0 var(--sp-4); }
      .footer__row { display: flex; align-items: center; justify-content: space-between; gap: var(--sp-4); flex-wrap: wrap; }
      .next {
        background: var(--structure); color: var(--on-structure);
        font-family: var(--sans); font-size: var(--fs-button); font-weight: 600;
        line-height: 1; letter-spacing: 0.18em; text-transform: uppercase;
        padding: 15px 22px; border: 0; border-radius: var(--radius); cursor: pointer;
      }
      .actions { display: flex; gap: var(--sp-4); }
      .ghost {
        background: none; border: 0; padding: 6px 2px; cursor: pointer;
        font-family: var(--sans); font-size: var(--fs-label); font-weight: 600;
        letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);
      }
      .ghost:hover { color: var(--ink); }

      .overlay {
        position: fixed; inset: 0; z-index: 20;
        display: flex; align-items: center; justify-content: center;
        padding: var(--margin-mobile);
        background: rgba(20, 17, 13, 0.35);
      }
      .overlay[hidden] { display: none; }
      .panel {
        position: relative;
        width: 100%; max-width: 440px;
        background: var(--paper-bright);
        border-top: var(--rule-heavy) solid var(--structure);
        padding: var(--sp-5) var(--sp-5) var(--sp-5);
      }
      .panel__close {
        position: absolute; top: 8px; right: 10px;
        background: none; border: 0; cursor: pointer;
        font-size: 24px; line-height: 1; color: var(--ink);
      }
      .about p { font-family: var(--sans); font-size: 15px; line-height: 1.6; color: var(--ink); margin: 0 0 var(--sp-3); }
      .about__closer { font-weight: 400; }
      .submit-link {
        display: inline-block; margin-top: var(--sp-3);
        font-family: var(--sans); font-size: 13px; font-weight: 600;
        color: var(--ink); text-decoration: underline; text-underline-offset: 3px;
      }
      .about__rule {
        height: var(--rule-hairline); background: var(--hairline); border: 0;
        margin: var(--sp-5) 0 var(--sp-4);
      }
      .about__footnote {
        margin: var(--sp-4) 0 0;
        font-family: var(--sans); font-size: 10.5px; font-weight: 400;
        line-height: 1.5; color: var(--muted); opacity: 0.85;
      }
      .about__legal {
        margin: 0;
        font-family: var(--sans); font-size: 11px; line-height: 1.5; color: var(--muted);
      }
      .panel__title { font-family: var(--sans); font-size: var(--fs-label); font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 var(--sp-3); }
      .share-item {
        display: block; width: 100%; text-align: left;
        background: none; border: 0; border-top: 1px solid var(--hairline);
        padding: 13px 2px; cursor: pointer;
        font-family: var(--serif); font-size: 17px; color: var(--ink); text-decoration: none;
      }
      .share-item[hidden] { display: none; }

      @media (min-width: 768px) {
        .toolbar { padding: var(--sp-5) var(--margin-desktop) 0; }
        .reader { padding: var(--sp-5) var(--margin-desktop) var(--sp-6); }
      }
    </style>
  </body>
</html>
