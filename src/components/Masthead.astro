---
// The full-bleed black masthead slab (DESIGN.md). Wordmark + verbatim tagline.
// Filter chips and Share/Save/About icons are added in Epics 2 and 3.
const tagline = 'Because a little bit of self-deprecation goes a long way.';
---
<header class="masthead">
  <div class="masthead__inner">
    <p class="masthead__wordmark">PM Off Mute</p>
    <p class="masthead__tagline">{tagline}</p>
  </div>
</header>

<style>
  .masthead { background: var(--structure); }
  .masthead__inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 22px var(--margin-mobile);
  }
  .masthead__wordmark {
    font-family: var(--serif);
    color: var(--on-structure);
    font-weight: 700;
    font-size: var(--fs-wordmark);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .masthead__tagline {
    color: var(--on-structure-muted);
    font-family: var(--sans);
    font-size: var(--fs-tagline);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin: 10px 0 0;
  }
  @media (min-width: 768px) {
    .masthead__inner { padding: 22px var(--margin-desktop); }
  }
</style>
